{
	"compilerOptions": {
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"allowImportingTsExtensions": true,
		"module": "ES2022",
		"moduleResolution": "Node"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
